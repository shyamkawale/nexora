# Database Configuration
# Example values - update with your actual database credentials
DB_URL=jdbc:postgresql://localhost:5432/svk-db?currentSchema=nexora_db
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# Database Connection Pool (HikariCP)
# Maximum pool size - limit concurrent DB connections (default: 10)
DB_HIKARI_MAXIMUM_POOL_SIZE=10
# Minimum idle connections - maintain warm connections (default: 10)
DB_HIKARI_MINIMUM_IDLE=2
# Connection timeout in milliseconds (20 seconds, default: 30000)
DB_HIKARI_CONNECTION_TIMEOUT=20000
# Idle timeout in milliseconds - close idle connections (5 minutes, default: 600000)
DB_HIKARI_IDLE_TIMEOUT=300000
# Max lifetime in milliseconds - connection max age (20 minutes, default: 1800000)
DB_HIKARI_MAX_LIFETIME=1200000

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Configuration
# Use a strong, random secret key for production (REQUIRED - no default)
JWT_SECRET=your_strong_jwt_secret_key_here_minimum_256_bits_recommended

# AWS S3 Configuration
# Store these securely and never commit them to version control (REQUIRED - no defaults)
AWS_ACCESS_KEY=your_aws_access_key_id
AWS_SECRET_KEY=your_aws_secret_access_key
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=your_s3_bucket_name
